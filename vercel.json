{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "version": 2,
    "buildCommand": "npm run build",
    "functions": {
        "api/index.js": {
            "maxDuration": 60,
            "regions": [
                "arn1",
                "fra1"
            ]
        }
    },
    "rewrites": [
        {
            "source": "/api",
            "destination": "/api/index"
        },
        {
            "source": "/api/:path*",
            "destination": "/api/index"
        },
        {
            "source": "/:path*",
            "destination": "/api/index"
        }
    ],
    "trailingSlash": false,
    "name": "edge-fu9mo8kxl6"
}
